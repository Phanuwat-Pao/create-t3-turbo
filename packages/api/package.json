{
  "name": "@acme/api",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./procedures": {
      "types": "./dist/orpc.d.ts",
      "default": "./src/orpc.ts"
    }
  },
  "scripts": {
    "ncu": "ncu -u",
    "build": "tsgo",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsgo --watch",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@acme/auth": "workspace:*",
    "@acme/db": "workspace:*",
    "@acme/validators": "workspace:*",
    "@aws-sdk/client-s3": "^3.1003.0",
    "@aws-sdk/s3-request-presigner": "^3.1003.0",
    "@orpc/server": "catalog:",
    "nanoid": "^5.1.6",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@acme/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "@typescript/native-preview": "catalog:",
    "vitest": "^4.0.8"
  }
}
