{
  "name": "guardtour",
  "private": true,
  "scripts": {
    "ncu": "ncu -u",
    "ncu:workspaces": "turbo run ncu",
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "auth:generate": "pnpm -F @acme/auth generate",
    "db:push": "turbo -F @acme/db push",
    "db:studio": "turbo -F @acme/db studio",
    "dev": "turbo watch dev --continue -F !@acme/expo",
    "dev:next": "turbo watch dev -F @acme/nextjs...",
    "dev:tui": "turbo watch dev --continue --ui tui",
    "e2e": "turbo run e2e -F @acme/e2e",
    "e2e:debug": "turbo run e2e:debug -F @acme/e2e",
    "e2e:headed": "turbo run e2e:headed -F @acme/e2e",
    "e2e:install": "pnpm --filter @acme/e2e e2e:install",
    "e2e:ui": "turbo run e2e:ui -F @acme/e2e",
    "check": "ultracite check",
    "check:fix": "ultracite fix",
    "lint:ws": "pnpm dlx sherif@latest",
    "postinstall": "pnpm lint:ws",
    "prepare": "lefthook install",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "@turbo/gen": "^2.9.4",
    "@typescript/native-preview": "catalog:",
    "dotenv-cli": "^11.0.0",
    "lefthook": "^2.1.5",
    "npm-check-updates": "^20.0.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "turbo": "^2.9.4",
    "ultracite": "7.4.3"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9.15.4"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild"
    ],
    "overrides": {
      "@types/minimatch": "5.1.2",
      "lightningcss": "1.30.1",
      "vite": "7.1.12"
    },
    "peerDependencyRules": {}
  }
}
